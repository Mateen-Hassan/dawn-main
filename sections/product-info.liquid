{% render 'cart-drawer' %}
{% style %}
  .container {
    display: flex;
    gap: 2rem;
  }

  .product-data {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  variant-picker {
    display: block;
  }

  variant-picker fieldset {
    border: none;
    margin: 0 0 1.6rem;
    padding: 0;
  }
  .quantity-selector {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .quantity-selector input {
    width: 6rem;
    padding: 0.8rem;
    border: 0.1rem solid rgba(var(--color-foreground), 0.2);
    border-radius: 0.4rem;
    text-align: center;
  }
  variant-picker legend {
    display: block;
    margin-bottom: 0.8rem;
    font-size: 1.4rem;
    font-weight: 500;
    color: rgb(var(--color-foreground));
  }

  variant-picker input[type='radio'] {
    clip: rect(0, 0, 0, 0);
    overflow: hidden;
    position: absolute;
    height: 1px;
    width: 1px;
  }

  variant-picker input[type='radio'] + label {
    display: inline-block;
    margin: 0 0.5rem 0.5rem 0;
    padding: 1rem 2rem;
    border: 0.1rem solid rgba(var(--color-foreground), 0.2);
    border-radius: 4rem;
    background-color: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
    font-size: 1.4rem;
    line-height: 1;
    letter-spacing: 0.1rem;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.15s ease
    , background-color 0.15s ease
    , color 0.15s ease;
  }

  variant-picker input[type='radio'] + label:hover {
    border-color: rgb(var(--color-foreground));
  }

  variant-picker input[type='radio']:checked + label {
    background-color: rgb(var(--color-foreground));
    border-color: rgb(var(--color-foreground));
    color: rgb(var(--color-background));
  }

  variant-picker input[type='radio']:focus-visible + label {
    box-shadow: 0 0 0 0.3rem rgb(var(--color-background))
    , 0 0 0 0.5rem rgba(var(--color-foreground), 0.55);
  }
{% endstyle %}
<script src="{{ 'variant-picker.js' | asset_url }}" defer="defer"></script>
<div class="container">
  <img
    src="{{ product.featured_image | image_url: width: 600 }}"
    alt="{{ product.featured_image.alt | escape }}"
    width="600"
    style="height: auto;">

  <div class="product-data">
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'title' %}
          <h1>{{ product.title }}</h1>
        {% when 'price' %}
          {{ product.selected_or_first_available_variant.price }}

        {% when 'add_to_cart' %}
          {% form 'product'
            , product %}
            <input
              type="hidden"
              name="id"
              value="{{ product.selected_or_first_available_variant.id }}">
            <div class="quantity-selector">
              <label for="quantity">Quantity</label>
              <input
                type="number"
                name="quantity"
                id="quantity"
                value="1"
                min="1"
                max="{{ product.selected_or_first_available_variant.inventory_quantity }}">
            </div>
            <button
              type="submit"
              {% unless product.selected_or_first_available_variant.available %}
              disabled
              {% endunless %}>
              {% if product.selected_or_first_available_variant.available %}
                Add to cart
              {% else %}
                Sold Out
              {% endif %}
            </button>
          {% endform %}
        {% when 'variants' %}
          {% unless product.has_only_default_variant %}
            <variant-picker data-section-id="{{section.id}}">
              {% for option in product.options_with_values %}
                <fieldset>
                  <legend>
                    {{ option.name }}
                  </legend>
                  {% for value in option.values %}
                    {% assign id = option.name | handleize | append: '-' | append: value | handleize %}
                    {% assign is_selected = value.selected %}
                    <input
                      type="radio"
                      name="{{ option.name | handleize }}"
                      value="{{ value }}"
                      id="{{ id }}"
                      data-option-value-id="{{ value.id }}"
                      {% if is_selected %}
                      checked{% endif %}>
                    <label for="{{ id }}">{{ value }}</label>
                  {% endfor %}
                </fieldset>
              {% endfor %}
            </variant-picker>
          {% endunless %}
      {% endcase %}
    {% endfor %}
  </div>
</div>
<script>
  document.addEventListener('submit', (event) => {
    const form = event.target.closest('form[action="/cart/add"]');
    if (!form || !form.closest('.product-data')) return;
  
    event.preventDefault();
  
    const cartDrawer = document.querySelector('cart-drawer');
    const config = fetchConfig('javascript');
    config.headers['X-Requested-With'] = 'XMLHttpRequest';
    delete config.headers['Content-Type'];
  
    const formData = new FormData(form);
    if (cartDrawer) {
      formData.append(
        'sections',
        cartDrawer.getSectionsToRender().map((section) => section.id)
      );
      formData.append('sections_url', window.location.pathname);
      cartDrawer.setActiveElement(document.activeElement);
    }
    config.body = formData;
  
    fetch(`${routes.cart_add_url}`, config)
      .then((response) => response.json())
      .then((response) => {
        if (response.status) {
          console.error(response.description);
          return;
        }
        if (!cartDrawer) {
          window.location = window.routes.cart_url;
          return;
        }
        cartDrawer.renderContents(response);
      })
      .catch(console.error);
  });
</script>
{% schema %}
  {
    "name": "Product Data",
    "settings": [],
    "blocks": [
      {
        "type": "title",
        "name": "Product Title",
        "settings": []
      }, {
        "type": "price",
        "name": "Product Price",
        "settings": []
      }, {
        "type": "add_to_cart",
        "name": "Add To Cart",
        "settings": []
      }, {
        "type": "variants",
        "name": "Variant picker",
        "settings": []
      }
    ],
    "presets": [
      {
        "name": "Product Data",
        "blocks": [
          {
            "type": "title"
          }, {
            "type": "price"
          }, {
            "type": "add_to_cart"
          }
        ]
      }
    ]
  }
{% endschema %}