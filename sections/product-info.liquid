{% style %}
  .container {
    display: flex;
    gap: 2rem;
  }

  .product-data {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
{% endstyle %}

<div class="container">
  <img
    src="{{ product.featured_image | image_url: width: 600 }}"
    alt="{{ product.featured_image.alt | escape }}"
    width="600"
    style="height: auto;">

  <div class="product-data">
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'title' %}
          <h1>{{ product.title }}</h1>
        {% when 'price' %}
          {{ product.price | money_with_currency }}
        {% when 'add_to_cart' %}
          {% form product
            , product %}
            <input
              type="hidden"
              name="id"
              value="{{product.selected_or_first_available_variant.id}}">
            <input
              type="hidden"
              name="quantity"
              value="1">
            <button
              type="submit"
              {% unless product.selected_or_first_available_variant.available %}
              disabled
              {% endunless %}>
              {% if product.selected_or_first_available_variant.available %}
                Add to cart
              {% else %}
                Sold Out
              {% endif %}
            </button>
          {% endform %}
      {% endcase %}
    {% endfor %}
  </div>
</div>

{% schema %}
  {
    "name": "Product Data",
    "settings": [],
    "blocks": [
      { 
        "type": "title",
        "name": "Product Title",
        "settings": []
      },
      { 
        "type": "price",
        "name": "Product Price",
        "settings": []
      },
      { 
        "type": "add_to_cart",
        "name": "Add To Cart",
        "settings": []
      }
    ],
    "presets": [
      {
        "name": "Product Data",
        "blocks": [
          { "type": "title" },
          { "type": "price" },
          { "type": "add_to_cart" }
        ]
      }
    ]
  }
  {% endschema %}
  