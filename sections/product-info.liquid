{% style %}
  .container{
    display: flex;
  }
.product-data{
    display: flex;
    flex-direction: column;
}
{% endstyle %}

<div class="container">
    <img src="{{ product.featured_image | image_url: width: 600 }}" 
     alt="{{ product.featured_image.alt | escape }}" 
     width="600" 
     height="auto">
     <div class="product-data">
        {{product.title }}
    {{ product.price | money_with_currency }}
    <form method="post" action="/cart/add">
    {%- for option in product-%}
          {%- for value in option.values -%}
            <input 
              type="radio" 
              name="{{ option.name }}" 
              value="{{ value | escape }}"
              {% if option.selected_value == value %}checked{% endif %}
            >
            <label>
              {{ value }}
            </label>
          {%- endfor -%}
    {%- endfor -%}
  <input type="hidden" name="id" value="{{ product.variants.first.id }}" />
  <label for="quantity">Quantity:</label>
  <input type="number" id="quantity" name="quantity" value="1" min="1" />
  <button type="submit" name="add" class="atcBtn">Add to Cart</button>
</form>

     </div>
    
</div>

<script>
const atcButton=document.querySelector('.atcBtn')
    atcButton.addEventListener('click', (event) => {
  event.preventDefault(); // Default behavior is now blocked
});

</script>
{% schema %}
{
  "name": "Custom Banner",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Welcome to our store"
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner Image"
    }
  ],
  "presets": [
    {
      "name": "Product Data",
      "settings": {
        
      }
    }
  ]
}
{% endschema %}
