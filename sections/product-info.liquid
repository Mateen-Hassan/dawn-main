{% style %}
  .container{
    display: flex;
  }
.product-data{
    display: flex;
    flex-direction: column;
}
{% endstyle %}

<div class="container">
    <img src="{{ product.featured_image | image_url: width: 600 }}" 
     alt="{{ product.featured_image.alt | escape }}" 
     width="600" 
     height="auto">
     <div class="product-data">
        {{product.title }}
    {{ product.price | money_with_currency }}
    <form method="post" action="/cart/add">
    
   {%- unless product.has_only_default_variant -%}
  {%- for option in product.options_with_values -%}
    <fieldset class="product-form__input">
      <legend>{{ option.name }}</legend>

      {%- for value in option.values -%}
        {%- assign input_id = section.id | append: '-' | append: option.position | append: '-' | append: forloop.index0 -%}

        <input
          type="radio"
          id="{{ input_id }}"
          name="{{ option.name }}"
          value="{{ value | escape }}"
          {% if value == option.selected_value %}checked{% endif %}
        >

        <label for="{{ input_id }}">{{ value }}</label>
      {%- endfor -%}
    </fieldset>
  {%- endfor -%}
{%- endunless -%} 
  <label for="quantity">Quantity:</label>
  <input type="number" id="quantity" name="quantity" value="1" min="1" />
  <button type="submit" name="add" class="atcBtn">Add to Cart</button>
</form>

     </div>
    
</div>

<script>
{% comment %} const atcButton=document.querySelector('.atcBtn')
    atcButton.addEventListener('click', (event) => {
  event.preventDefault(); 
}); {% endcomment %}

</script>
{% schema %}
{
  "name": "Custom Banner",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Welcome to our store"
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner Image"
    }
  ],
  "presets": [
    {
      "name": "Product Data",
      "settings": {
        
      }
    }
  ]
}
{% endschema %}
