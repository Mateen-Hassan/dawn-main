{% style %}
  .container{
    display: flex;
  }
.product-data{
    display: flex;
    flex-direction: column;
}
{% endstyle %}

<div class="container">
    <img src="{{ product.featured_image | image_url: width: 600 }}" 
     alt="{{ product.featured_image.alt | escape }}" 
     width="600" 
     height="auto">
     <div class="product-data">
        {{product.title }}
    {{ product.price | money_with_currency }}
    <form method="post" action="/cart/add">
    
  <div class="variant-selector">
    {% for option in product.options_with_values %}
      <label >
        {{ option.name }}
      </label>
      
      <select id="Option-{{ forloop.index0 }}" name="options[{{ option.name | escape }}]">
        {% for value in option.values %}
          <option value="{{ value | escape }}" {% if option.selected_value == value %}selected="selected"{% endif %}>
            {{ value }}
          </option>
        {% endfor %}
      </select>
    {% endfor %}
  </div>

  {% comment %} <input type="hidden" name="id" value="{{ product.variants.first.id }}" /> {% endcomment %}
  <label for="quantity">Quantity:</label>
  <input type="number" id="quantity" name="quantity" value="1" min="1" />
  <button type="submit" name="add" class="atcBtn">Add to Cart</button>
</form>

     </div>
    
</div>

<script>
{% comment %} const atcButton=document.querySelector('.atcBtn')
    atcButton.addEventListener('click', (event) => {
  event.preventDefault(); 
}); {% endcomment %}

</script>
{% schema %}
{
  "name": "Custom Banner",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Welcome to our store"
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner Image"
    }
  ],
  "presets": [
    {
      "name": "Product Data",
      "settings": {
        
      }
    }
  ]
}
{% endschema %}
