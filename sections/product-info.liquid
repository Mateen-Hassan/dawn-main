{% style %}
  .container{
    display: flex;
  }
{% endstyle %}

<div class="container">
    <img src="{{ product.featured_image | image_url: width: 600 }}" 
     alt="{{ product.featured_image.alt | escape }}" 
     width="600" 
     height="auto">
     <div>
        {{product.title }}
    {{ product.price | money_with_currency }}
     </div>
    
</div>

{% schema %}
{
  "name": "Custom Banner",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Welcome to our store"
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner Image"
    }
  ],
  "presets": [
    {
      "name": "Product Data",
      "settings": {
        
      }
    }
  ]
}
{% endschema %}
