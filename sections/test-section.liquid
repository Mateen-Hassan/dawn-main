{{ 'test-section-style.css' | asset_url | stylesheet_tag }}

<div class="gift-guide-section" style="background-color: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }};">
  
  <!-- Top Bar -->
  <div class="gg-top-bar">
    <div class="gg-brand">{{ section.settings.brand_text }}</div>
    <div class="gg-top-text">{{ section.settings.pre_heading }}</div>
    <a href="{{ section.settings.btn_link_1 }}" class="gg-top-btn" style="background-color: {{ section.settings.accent_color }};">
      {{ section.settings.btn_text_1 }} <span class="arrow">&rarr;</span>
    </a>
  </div>

  <div class="gg-main-grid">
    <!-- LEFT HALF: Illustrations (Desktop) -->
    <div class="gg-illustrations">
      <div class="illus-item i-glasses"><svg viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 30 C15 30, 5 40, 5 55 C5 70, 15 80, 25 80 C35 80, 40 70, 40 60 L45 55 L55 55 L60 60 C60 70, 65 80, 75 80 C85 80, 95 70, 95 55 C95 40, 85 30, 80 30" /><circle cx="22" cy="58" r="12"/><circle cx="78" cy="58" r="12"/><line x1="45" y1="55" x2="55" y2="55"/></svg></div>
      <div class="illus-item i-map"><svg viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="10" y="10" width="80" height="80" /><path d="M15 20 Q30 30 25 50 T45 70 T75 50" stroke-dasharray="2 2"/><circle cx="30" cy="40" r="15"/><circle cx="70" cy="60" r="8"/><circle cx="50" cy="30" r="5"/></svg></div>
      <div class="illus-item i-camera"><svg viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="2"><rect x="20" y="30" width="60" height="40" rx="5"/><rect x="35" y="15" width="30" height="15" rx="2"/><circle cx="50" cy="50" r="12"/><rect x="75" y="40" width="10" height="5"/><circle cx="50" cy="50" r="4" fill="currentColor"/></svg></div>
      <div class="illus-item i-compass"><svg viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="50" cy="50" r="35"/><circle cx="50" cy="50" r="28"/><polygon points="50,25 60,50 50,45 40,50" fill="currentColor"/><line x1="50" y1="15" x2="50" y2="85"/><line x1="15" y1="50" x2="85" y2="50"/></svg></div>
      <div class="illus-item i-notebook"><svg viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="20" y="10" width="60" height="80" rx="3"/><line x1="35" y1="20" x2="65" y2="20"/><line x1="35" y1="30" x2="65" y2="30"/><line x1="35" y1="40" x2="65" y2="40"/><line x1="35" y1="50" x2="55" y2="50"/></svg></div>
      <div class="illus-item i-watch"><svg viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="2"><rect x="20" y="42" width="60" height="16" rx="8"/><circle cx="50" cy="50" r="12"/><line x1="50" y1="50" x2="55" y2="45"/><line x1="50" y1="50" x2="50" y2="56"/></svg></div>
      <div class="illus-item i-lens"><svg viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="30" y="10" width="40" height="80" rx="5"/><rect x="25" y="20" width="50" height="15" rx="2"/><rect x="25" y="65" width="50" height="15" rx="2"/><circle cx="50" cy="50" r="10"/></svg></div>
      <div class="illus-item i-bow"><svg viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="2"><path d="M50 50 C30 30, 10 60, 50 80 C90 60, 70 30, 50 50Z"/><circle cx="50" cy="55" r="5"/></svg></div>
      <!-- Add more placeholder divs as needed for responsive grid fill -->
    </div>

    <!-- RIGHT HALF: Content -->
    <div class="gg-content">
      <h2 class="gg-heading">{{ section.settings.heading }}</h2>
      <div class="gg-desc">{{ section.settings.description }}</div>
      <a href="{{ section.settings.btn_link_2 }}" class="gg-main-btn">
        {{ section.settings.btn_text_2 }} <span class="arrow">&rarr;</span>
      </a>
    </div>
  </div>

  <!-- Footer -->
  <div class="gg-footer">
    {{ section.settings.footer_text }}
  </div>

</div>
{% schema %}
{
  "name": "Gift Guide",
  "settings": [
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "text",
      "id": "brand_text",
      "label": "Brand Text",
      "default": "TISSO VISON"
    },
    {
      "type": "text",
      "id": "pre_heading",
      "label": "Small Top Text",
      "default": "Find the ideal gift for your loved ones."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main Heading",
      "default": "The Gift Guide"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season."
    },
    {
      "type": "text",
      "id": "btn_text_1",
      "label": "Top Right Button Text",
      "default": "CHOOSE GIFT"
    },
    {
      "type": "url",
      "id": "btn_link_1",
      "label": "Top Right Button Link"
    },
    {
      "type": "text",
      "id": "btn_text_2",
      "label": "Main Button Text",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "btn_link_2",
      "label": "Main Button Link"
    },
    {
      "type": "text",
      "id": "footer_text",
      "label": "Footer Text",
      "default": "SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL"
    },
    {
      "type": "header",
      "content": "Colors & Styling"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color (Buttons)",
      "default": "#fce300"
    }
  ],
  "presets": [
    {
      "name": "Gift Guide Layout",
      "category": "Image & Text"
    }
  ]
}
{% endschema %}