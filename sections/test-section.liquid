{{ 'test-section-style.css' | asset_url | stylesheet_tag }}

<div class="gift-guide-wrapper">
  <div class="gift-guide-section" style="color: {{ section.settings.text_color }};">
    
    <!-- Background Image & Color -->
    <div class="gg-background" style="background-color: {{ section.settings.bg_color }}; {% if section.settings.bg_image != blank %}background-image: url('{{ section.settings.bg_image | image_url: width: 1400 }}');{% endif %}">
      
      <!-- CSS Fallback Pattern (Visible only if no bg image is uploaded) -->
      <div class="gg-css-grid-bg">
        <span class="box"></span><span class="box"></span><span class="box"></span>
        <span class="box"></span><span class="box"></span><span class="box"></span>
        <span class="box"></span><span class="box"></span><span class="box"></span>
      </div>
    </div>

    <!-- Foreground Content Wrapper -->
    <div class="gg-content-wrapper">
      
      <!-- Top Bar -->
      <div class="gg-top-bar">
        <div class="gg-brand">{{ section.settings.brand_text }}</div>
        <div class="gg-top-text">{{ section.settings.pre_heading }}</div>
        <a href="{{ section.settings.btn_link_1 }}" class="gg-top-btn" style="background-color: {{ section.settings.accent_color }};">
          {{ section.settings.btn_text_1 }} <span class="arrow">&rarr;</span>
        </a>
      </div>

      <!-- Main Grid -->
      <div class="gg-main-grid">
        <!-- Left Spacer (Takes up space where the illustration is) -->
        <div class="gg-image-spacer"></div>

        <!-- Right Content -->
        <div class="gg-content">
          <h2 class="gg-heading">{{ section.settings.heading }}</h2>
          <div class="gg-desc">{{ section.settings.description }}</div>
          <a href="{{ section.settings.btn_link_2 }}" class="gg-main-btn">
            {{ section.settings.btn_text_2 }} <span class="arrow">&rarr;</span>
          </a>
        </div>
      </div>

      <!-- Footer -->
      <div class="gg-footer">
        {{ section.settings.footer_text }}
      </div>

    </div>
  </div>
</div>
{% schema %}
{
  "name": "Gift Guide",
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image",
      "info": "Upload your line-art illustration grid here. Recommended size: 1400x800px."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Fallback Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "text",
      "id": "brand_text",
      "label": "Brand Text",
      "default": "TISSO VISON"
    },
    {
      "type": "text",
      "id": "pre_heading",
      "label": "Small Top Text",
      "default": "Find the ideal gift for your loved ones."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main Heading",
      "default": "The Gift Guide"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season."
    },
    {
      "type": "text",
      "id": "btn_text_1",
      "label": "Top Right Button Text",
      "default": "CHOOSE GIFT"
    },
    {
      "type": "url",
      "id": "btn_link_1",
      "label": "Top Right Button Link"
    },
    {
      "type": "text",
      "id": "btn_text_2",
      "label": "Main Button Text",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "btn_link_2",
      "label": "Main Button Link"
    },
    {
      "type": "text",
      "id": "footer_text",
      "label": "Footer Text",
      "default": "SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL"
    },
    {
      "type": "header",
      "content": "Colors & Styling"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color (Yellow Button)",
      "default": "#fce300"
    }
  ],
  "presets": [
    {
      "name": "Gift Guide Layout",
      "category": "Image & Text"
    }
  ]
}
{% endschema %}

