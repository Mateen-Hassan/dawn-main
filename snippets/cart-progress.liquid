{{ 'cart-progress.js' | asset_url | script_tag }}

<style>
  .main-container {
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 6px;
    flex-direction: column;
  }
  .progressPath {
    width: 100%;
    height: 10px;
    background: #e5e7eb;
    border-radius: 999px;
    overflow: hidden;
  }
  .progress-bar {
    height: 10px;
    background: blue;
    border-radius: 999px;
    overflow: hidden;
    display: block !important;
  }
</style>
{% assign cartTotal = cart.total_price %}
{% assign threshHold = 2000 | times: 100 %}

<div class="main-container" data-set="{{threshHold}}">
  <div class="message">
    {% if cartTotal >= threshHold %}
      <p>Greate Work! {{ cartTotal }} and {{ threshHold }}</p>
    {% else %}
      {% assign remaining = threshHold | minus: cartTotal | money_without_trailing_zeros %}
      <p>Add more
        <strong>{{ remaining }}</strong>!</p>
    {% endif %}


  </div>
  <div class="progressPath">
    <div class="progress-bar" style="width:{% if cartTotal >= threshHold%}100%{%else%}{{ cartTotal | times: 100 | divided_by: threshHold }}%{% endif %};"></div>
  </div>
</div>